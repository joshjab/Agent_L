#!/usr/bin/env bash
# pre-commit hook for Agent-L
#
# Always runs:   cargo check + clippy + unit/integration tests + fmt
# When Ollama is reachable: also runs the live_pipeline tests (#[ignore])
#
# Activate once per clone:
#   git config core.hooksPath .githooks
#
# To skip (emergency only):
#   git commit --no-verify

set -euo pipefail

CARGO="${HOME}/.cargo/bin/cargo"
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # no colour

fail() { echo -e "${RED}[pre-commit] FAILED: $*${NC}" >&2; exit 1; }
warn() { echo -e "${YELLOW}[pre-commit] WARNING: $*${NC}" >&2; }
ok()   { echo -e "${GREEN}[pre-commit] $*${NC}"; }

# ── 1. Fast suite (always required) ─────────────────────────────────────────

echo "[pre-commit] Running fast suite (check / clippy / test / fmt)…"

"$CARGO" check --quiet           || fail "cargo check"
"$CARGO" clippy -- -D warnings   || fail "cargo clippy"
"$CARGO" test                    || fail "cargo test"
"$CARGO" fmt --check             || fail "cargo fmt --check  (run: cargo fmt)"

ok "Fast suite passed."

# ── 2. Live suite (runs when Ollama is reachable) ────────────────────────────

# Load .env so OLLAMA_HOST/PORT/MODEL reflect the project config rather than
# falling back to hardcoded defaults when the shell has no env vars set.
if [ -f .env ]; then
    # Export only simple KEY=VALUE lines; skip comments and blank lines.
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
fi

OLLAMA_HOST="${OLLAMA_HOST:-localhost}"
OLLAMA_PORT="${OLLAMA_PORT:-11434}"

echo "[pre-commit] Checking Ollama at ${OLLAMA_HOST}:${OLLAMA_PORT}…"

if curl -sf --max-time 2 "http://${OLLAMA_HOST}:${OLLAMA_PORT}/api/tags" > /dev/null 2>&1; then
    ok "Ollama reachable — running live_pipeline tests…"
    "$CARGO" test --test live_pipeline -- --ignored \
        || fail "live_pipeline tests failed (run with --nocapture to debug)"
    ok "Live suite passed."

    # ── 3. Factual review (manual sign-off required) ─────────────────────────
    echo ""
    echo "[pre-commit] Running factual review tests (read the output carefully)…"
    "$CARGO" test --test live_factual_review -- --ignored --nocapture \
        || fail "live_factual_review tests failed"

    echo ""
    if [ -t 0 ]; then
        # Interactive terminal — ask the committer to sign off on the answers.
        read -rp "[pre-commit] Review the factual answers above. Do they look correct? [y/N] " _confirm
        if [[ "$_confirm" != "y" && "$_confirm" != "Y" ]]; then
            fail "Factual review rejected — fix the answers before committing"
        fi
        ok "Factual review approved."
    else
        warn "Non-interactive — skipping factual review sign-off prompt."
        warn "Run manually and verify answers before merging to main:"
        warn "  cargo test --test live_factual_review -- --ignored --nocapture"
    fi
else
    warn "Ollama not reachable at ${OLLAMA_HOST}:${OLLAMA_PORT} — skipping live tests."
    warn "Start Ollama and run manually before merging to main:"
    warn "  cargo test --test live_pipeline -- --ignored --nocapture"
    warn "  cargo test --test live_factual_review -- --ignored --nocapture"
fi
